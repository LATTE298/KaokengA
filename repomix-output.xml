      body: SafeArea(
        child: Stack(
          children: [
            ChildAsyncView(
              value: asyncPack,
              error:
                  (_, __) =>
                      Center(child: Text('เนเธซเธฅเธ”เนเธกเนเธชเธณเน€เธฃเนเธ', style: kTextLg)),
              data: (pack) => _MemoryBoard(pack: pack),
            ),
