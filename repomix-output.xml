<file path="firestore.rules">
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Publicly readable content (scenarios, memory packs, vocabulary).
    match /content/{document=**} {
      allow read: if true;
      allow write: if false;
    }

    // Per-user data: only the owner can read or write.
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    match /sessions/{uid}/records/{sessionId} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    match /scenario_settings/{uid}/overrides/{scenarioId} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Default deny.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
